# Both keys are OPTIONAL. With neither set, the app runs in full demo mode:
# bundled job postings + the deterministic skill engine. Add a key to upgrade
# that half of the pipeline to live data / AI extraction.

# Enables AI-powered skill extraction from uploaded curricula (structured tool use).
# Without it, extraction falls back to the deterministic taxonomy matcher.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Enables live job listings via JSearch (RapidAPI). Without it, the app serves a
# bundled corpus of realistic postings so the full flow still works.
# Get one at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Optional: override the model used for AI skill extraction (default: claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8
